{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "local/src/renderer/**/*",
    "src/renderer/src/**/*",
    "src/main/integration/cherryai/index.js",
    "src/preload/*.d.ts",
    "tests/__mocks__/**/*",
    "packages/aiCore/src/**/*",
    "packages/ai-sdk-provider/**/*",
    "packages/extension-table-plus/**/*",
    "packages/mcp-trace/**/*",
    "packages/shared/**/*"
  ],
  "exclude": [
    "packages/aiCore/src/**/__tests__/**",
    "src/renderer/src/**/__tests__/**",
    "src/renderer/src/**/*.test.ts",
    "src/renderer/src/**/*.test.tsx",
    "src/renderer/src/**/*.spec.ts",
    "src/renderer/src/**/*.spec.tsx",
    "src/renderer/src/components/Popups/agent/**/*",
    "src/renderer/src/components/Tab/**/*",
    "src/renderer/src/pages/agents/**/*",
    "src/renderer/src/pages/code/**/*",
    "src/renderer/src/pages/files/FilesPage.tsx",
    "src/renderer/src/pages/files/FileList.tsx",
    "src/renderer/src/pages/knowledge/**/*",
    "src/renderer/src/pages/launchpad/**/*",
    "src/renderer/src/pages/minapps/**/*",
    "src/renderer/src/pages/notes/**/*",
    "src/renderer/src/pages/openclaw/**/*",
    "src/renderer/src/pages/paintings/**/*",
    "src/renderer/src/pages/settings/ChannelsSettings/**/*",
    "src/renderer/src/pages/settings/AgentSettings/**/*",
    "src/renderer/src/pages/settings/QuickAssistantSettings.tsx",
    "src/renderer/src/pages/home/Inputbar/tools/permissionModeTool.tsx",
    "src/renderer/src/pages/home/Messages/PermissionModeDisplay.tsx",
    "src/renderer/src/pages/store/**/*",
    "src/renderer/src/pages/translate/**/*",
    "src/renderer/src/services/FileAction.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo/tsconfig.web.tsbuildinfo",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "paths": {
      "@logger": ["./src/renderer/src/services/LoggerService"],
      "@renderer/*": ["./src/renderer/src/*"],
      "@shared/*": ["./packages/shared/*"],
      "@types": ["./src/renderer/src/types/index.ts"],
      "@mcp-trace/*": ["./packages/mcp-trace/*"],
      "@cherrystudio/ai-core/provider": ["./packages/aiCore/src/core/providers/index.ts"],
      "@cherrystudio/ai-core/built-in/plugins": ["./packages/aiCore/src/core/plugins/built-in/index.ts"],
      "@cherrystudio/ai-core/*": ["./packages/aiCore/src/*"],
      "@cherrystudio/ai-core": ["./packages/aiCore/src/index.ts"],
      "@cherrystudio/extension-table-plus": ["./packages/extension-table-plus/src/index.ts"],
      "@cherrystudio/ai-sdk-provider": ["./packages/ai-sdk-provider/src/index.ts"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": true
  }
}
